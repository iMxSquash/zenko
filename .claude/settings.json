{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./.env.local)",
      "Read(./.env.production)",
      "Read(./secrets/**)",
      "Read(./dist/**)",
      "Read(./build/**)",
      "Edit(./node_modules/**)",
      "Read(./.git/config)",
      "Bash(rm -rf /)",
      "Bash(DROP TABLE *)",
      "Bash(truncate *)"
    ],
    "ask": ["Bash(git commit *)", "Bash(git push *)", "Bash(npm install *)", "Bash(npm i *)"],
    "allow": [
      "Read(./**)",
      "Write(./src/**)",
      "Write(./supabase/**)",
      "Write(./docs/**)",
      "Write(./.claude/**)",
      "Write(./public/**)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git stash *)",
      "Bash(git pull *)",
      "Bash(npm run *)",
      "Bash(npm test)",
      "Bash(npm ci)",
      "Bash(npx tsc *)",
      "Bash(npx vitest *)",
      "Bash(npx vite *)",
      "Bash(npx tsx *)",
      "Bash(node src/**)",
      "Bash(node supabase/**)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(which *)",
      "Bash(find *)"
    ]
  }
}
