{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(self), geolocation=(), payment=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://*.supabase.co wss://*.supabase.co; img-src 'self' data: blob: https://*.supabase.co; font-src 'self' data:; media-src 'self'; worker-src 'self'; frame-ancestors 'none'; form-action 'self'; base-uri 'self';" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://aqyvrumakemtyoouoodc.supabase.co/functions/v1/sitemap"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(bot|crawler|spider|slurp|facebookexternalhit|whatsapp|telegrambot|discordbot|gptbot|chatgpt-user|claudebot|claude-web|anthropic-ai|perplexitybot|ccbot|google-extended|bytespider|amazonbot|petalbot|applebot|duckduckbot).*"
        }
      ],
      "destination": "https://aqyvrumakemtyoouoodc.supabase.co/functions/v1/prerender?path=/"
    },
    {
      "source": "/bibliotheque",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(bot|crawler|spider|slurp|facebookexternalhit|whatsapp|telegrambot|discordbot|gptbot|chatgpt-user|claudebot|claude-web|anthropic-ai|perplexitybot|ccbot|google-extended|bytespider|amazonbot|petalbot|applebot|duckduckbot).*"
        }
      ],
      "destination": "https://aqyvrumakemtyoouoodc.supabase.co/functions/v1/prerender?path=/bibliotheque"
    },
    {
      "source": "/bibliotheque/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(bot|crawler|spider|slurp|facebookexternalhit|whatsapp|telegrambot|discordbot|gptbot|chatgpt-user|claudebot|claude-web|anthropic-ai|perplexitybot|ccbot|google-extended|bytespider|amazonbot|petalbot|applebot|duckduckbot).*"
        }
      ],
      "destination": "https://aqyvrumakemtyoouoodc.supabase.co/functions/v1/prerender?path=/bibliotheque/:slug"
    },
    {
      "source": "/forum",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(bot|crawler|spider|slurp|facebookexternalhit|whatsapp|telegrambot|discordbot|gptbot|chatgpt-user|claudebot|claude-web|anthropic-ai|perplexitybot|ccbot|google-extended|bytespider|amazonbot|petalbot|applebot|duckduckbot).*"
        }
      ],
      "destination": "https://aqyvrumakemtyoouoodc.supabase.co/functions/v1/prerender?path=/forum"
    },
    {
      "source": "/forum/:threadId",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(bot|crawler|spider|slurp|facebookexternalhit|whatsapp|telegrambot|discordbot|gptbot|chatgpt-user|claudebot|claude-web|anthropic-ai|perplexitybot|ccbot|google-extended|bytespider|amazonbot|petalbot|applebot|duckduckbot).*"
        }
      ],
      "destination": "https://aqyvrumakemtyoouoodc.supabase.co/functions/v1/prerender?path=/forum/:threadId"
    }
  ]
}
